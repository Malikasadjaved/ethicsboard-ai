# =============================================================
# EthicsBoard AI — Environment Variables
# =============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git!

# ----- Band Platform (thenvoi-sdk) -----
# Platform URLs (from official docs)
THENVOI_REST_URL=https://app.band.ai/
THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket

# Agent credentials go in agent_config.yaml (see below)
# The SDK reads them via: load_agent_config("protocol_agent")
#
# agent_config.yaml format:
#   protocol_agent:
#     agent_id: "<uuid>"
#     api_key: "<key>"
#   ethics_agent:
#     agent_id: "<uuid>"
#     api_key: "<key>"
#   privacy_agent:
#     agent_id: "<uuid>"
#     api_key: "<key>"
#   committee_agent:
#     agent_id: "<uuid>"
#     api_key: "<key>"

# IRB Chair (human) — Band user ID for add_participant
BAND_IRB_CHAIR_USER_ID=<your_band_user_uuid>

# ----- AI/ML API (aimlapi.com) -----
AIML_API_KEY=
AIML_BASE_URL=https://api.aimlapi.com/v1

# ----- Featherless AI (featherless.ai) -----
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1

# ----- Application -----
APP_ENV=development
DASHBOARD_PORT=3000
API_PORT=8000

# ----- Testing -----
TEST_MODE=false
